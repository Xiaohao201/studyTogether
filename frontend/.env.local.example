# Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# Gaode Map (AMap) Configuration (required for map functionality)
# Get your key and secret at: https://console.amap.com/
# 1. Register a new application at AMap Open Platform
# 2. Create a Web端 (JS API) key
# 3. Copy the Key and Security Key (Secret) below
NEXT_PUBLIC_AMAP_KEY=your_amap_key_here
NEXT_PUBLIC_AMAP_SECRET=your_amap_secret_here

# Backend API URL
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# WebRTC TURN server (for NAT traversal, needed for video/voice calls)
# Option 1: Metered TURN (recommended for production)
# Sign up at https://www.metered.ca/tools/openrelay/ and get your API key
# Replace YOUR_APP_NAME with your Metered app name
NEXT_PUBLIC_METERED_TURN_URL=https://YOUR_APP_NAME.metered.live/api/v1/turn/credentials?apiKey=YOUR_API_KEY

# Option 2: Self-hosted TURN (local dev only)
# Start TURN server: docker-compose up -d turn
# NEXT_PUBLIC_TURN_SERVER_URL=turn:localhost:3478
# NEXT_PUBLIC_TURN_USERNAME=studytogether
# NEXT_PUBLIC_TURN_CREDENTIAL=turn-dev-password
