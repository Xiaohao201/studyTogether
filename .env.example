# ================================
# DATABASE CONFIGURATION
# ================================
# Railway will provide DATABASE_URL automatically when you add PostgreSQL service
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://studytogether:studytogether_dev_password@localhost:5432/studytogether

# Individual database credentials (for local development)
POSTGRES_USER=studytogether
POSTGRES_PASSWORD=studytogether_dev_password
POSTGRES_DB=studytogether

# ================================
# SECURITY / JWT
# ================================
# Generate a strong random key for production: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production

# Token expiration times
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ================================
# API KEYS
# ================================
# Get your Amap (高德地图) API key from: https://console.amap.com/
NEXT_PUBLIC_AMAP_KEY=your_amap_key_here
NEXT_PUBLIC_AMAP_SECRET=your_amap_secret_here

# ================================
# TURN SERVER (WebRTC NAT traversal)
# ================================
# For production, use Twilio Network Traversal or deploy coturn on a server
# For local development, use the coturn container in docker-compose.yml
TURN_SERVER_URL=turn:localhost:3478
TURN_USERNAME=studytogether
TURN_CREDENTIAL=turn-dev-password

# ================================
# SERVICE URLs
# ================================
# Backend API URL (for frontend to call)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Frontend URL (for CORS and WebSocket origin validation)
FRONTEND_URL=http://localhost:3000

# Backend URL (for internal references)
BACKEND_URL=http://localhost:8000

# ================================
# ENVIRONMENT
# ================================
# Options: development, staging, production
ENVIRONMENT=development

# ================================
# RAILWAY-SPECIFIC VARIABLES
# ================================
# These will be automatically set by Railway:
# - PORT: The port Railway expects your app to listen on
# - RAILWAY_ENVIRONMENT: The Railway environment name
# - RAILWAY_SERVICE_NAME: The service name
# - RAILWAY_PROJECT_NAME: The project name

# ================================
# OPTIONAL: LOGGING & MONITORING
# ================================
# LOG_LEVEL=info
# SENTRY_DSN=your_sentry_dsn_here
